# TouchDesigner temp
*.toe
*.toe.lock
/tmp/

# Scratch TD projects inside td_component (build artifacts)
td_component/NewProject*.toe

# Generated QA artifacts (repo-root /reports/ only — don't swallow
# docs/superpowers/reports/ which holds session review artifacts)
/reports/
zivfETsb

# Coverage artifacts (coverage.xml is uploaded by CI; .coverage is local)
.coverage
.coverage.*
coverage.xml
htmlcov/

# .mcp.json at repo root IS the Claude Code plugin template (committed).
# User-rendered local variants and backups are NOT tracked.
.mcp.json.local
.mcp.json.local-backup
.mcp.json.backup*

# tdpilot.plugin is a release artifact rebuilt by scripts/build_plugin_zip.py
# from committed sources. Not tracked in git — users get the committed source
# tree via Claude Code marketplace install. Release CI publishes the ZIP.
tdpilot.plugin

# tdpilot.mcpb is a Claude Desktop one-click-install bundle, rebuilt by
# scripts/build_mcpb.py from committed sources. Same not-tracked pattern as
# tdpilot.plugin — published via GitHub Releases for Claude Desktop users.
tdpilot.mcpb

# Staging directory used by scripts/build_mcpb.py during pack
.mcpb-build/

# Secret env file written by installer (contains TD_MCP_SHARED_SECRET)
.tdpilot.env

# User data — written by the running TDPilot server into the install dir
# when ``~/.tdpilot/`` IS the install (npx-tdpilot pattern). Both subtrees
# hold per-user content (technique recipes, knowledge essays, snapshots)
# that must NEVER end up in the public repo. Defense-in-depth even though
# nothing should ``git add`` them — keeps a stray ``git add -A`` in the
# install dir from accidentally staging private notes for a push.
#
# IMPORTANT: leading slash is REQUIRED. Without it, ``memory/`` matches
# ANY directory named "memory" anywhere in the tree — including the
# source code's ``src/td_mcp/memory/``, silently swallowing new files
# added there. Anchoring with ``/memory/`` scopes the rule to repo-root
# only, which is exactly where the user-data dirs live in an
# ``~/.tdpilot/`` install.
/memory/
/knowledge/

# Dev tooling scratch
.playwright-mcp/
.claude/

# Git worktrees
.worktrees/

# Brain runtime config (generated by installer, not tracked)
data/brains/active.json
data/normalized/

# Archived docs — plans, version-specific implementation notes, runtime
# strategy/roadmap drafts, retired session reports. Kept locally but not
# published. The public docs/ tree contains only current-state user-facing
# documentation; anything that drifts off-purpose ends up here.
docs/archive/

# Public-repo docs policy (audit 2026-05-04): only README.md (root) and
# docs/MANUAL.md are tracked. Every other free-form markdown file at the
# repo root or directly under docs/ stays local. Runtime-functional .md
# (skills/*/SKILL.md, commands/*.md, npm/README.md,
# td_component/{knowledge,skills}/*.md, td_component/README.md,
# skills/*/references/*.md) is NOT covered by this rule — those are
# loaded by the plugin / baked into the .tox / shipped via npm.
/docs/*.md
!/docs/MANUAL.md
# Chunk Schema v1 — code-adjacent contract spec referenced by builders,
# tests, and runtime readers (see scripts/_chunk_schema_v1.py). Not
# free-form planning doc — exempt from the docs/ ignore.
!/docs/CHUNK_SCHEMA.md
!/CHANGELOG.md
/CLAUDE.md
# plugin_README.md is bundled as README.md inside the Claude Code plugin
# .zip (scripts/build_plugin_zip.py). Keep it tracked — it's functional
# infrastructure shipped to plugin marketplace users, not free-form docs.

# Atlas / corpus content for licensed third-party libraries.
# Build manifests at data/brains/*.yaml point at user-supplied paths
# via env vars; the actual reference data stays out of the public repo.
data/normalized/popx/
